    "@vitejs/plugin-react": "^5.1.2",
    "date-fns": "^4.1.0",
    "html-to-pdfmake": "^2.5.32",
    "i18next": "^25.7.4",
    "markdown-it": "^14.1.0",
    "npm": "^11.7.0",
